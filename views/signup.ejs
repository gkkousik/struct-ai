<% layout('layout') -%>

<% block('head').append(`
<style>
  .auth-card {
    box-shadow:
      0 0 40px rgba(16,185,129,.12),
      0 0 80px rgba(124,58,237,.08),
      inset 0 1px 0 rgba(255,255,255,.06);
  }
  .logo-glow { box-shadow: 0 0 24px rgba(16,185,129,.55); }
  .strength-bar { height: 4px; border-radius: 2px; transition: width .3s, background .3s; }
</style>
`) %>

<div class="min-h-[calc(100vh-80px)] flex items-center justify-center px-4 py-16">
  <div class="glass auth-card w-full max-w-md rounded-2xl p-8 md:p-10" data-aos="fade-up">

    <div class="flex flex-col items-center mb-8">
      <img src="/com_logo.png" alt="Structura AI"
           class="h-16 w-16 rounded-full logo-glow mb-3 ring-2 ring-emerald-500/30" />
      <h1 class="text-2xl font-extrabold gradient-text">Structura AI</h1>
      <p class="text-gray-400 text-sm mt-1">Create your free account</p>
    </div>

    <% if (error) { %>
    <div class="mb-5 flex items-start gap-3 bg-red-950/60 border border-red-500/40 text-red-300 px-4 py-3 rounded-xl text-sm">
      <span class="text-red-400 mt-0.5">⚠</span>
      <span><%= error %></span>
    </div>
    <% } %>

    <form method="POST" action="/signup" id="signupForm" class="space-y-4">

      <div>
        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">
          Username
        </label>
        <input type="text" name="username" required autocomplete="username"
          class="input-field w-full px-4 py-3 rounded-xl text-sm text-gray-100 placeholder-gray-600"
          placeholder="cool_username" minlength="3" maxlength="30" />
      </div>

      <div>
        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">
          Email
        </label>
        <input type="email" name="email" required autocomplete="email"
          class="input-field w-full px-4 py-3 rounded-xl text-sm text-gray-100 placeholder-gray-600"
          placeholder="you@example.com" />
      </div>

      <div>
        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">
          Password
        </label>
        <div class="relative">
          <input type="password" name="password" id="pw" required autocomplete="new-password"
            class="input-field w-full px-4 py-3 pr-12 rounded-xl text-sm text-gray-100 placeholder-gray-600"
            placeholder="Min. 6 characters" minlength="6" />
          <button type="button" id="togglePw"
            class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 hover:text-emerald-400 transition text-sm">
            👁
          </button>
        </div>
        <div class="mt-2 bg-white/10 rounded-full overflow-hidden">
          <div id="strengthBar" class="strength-bar w-0 bg-red-500"></div>
        </div>
        <p id="strengthLabel" class="text-xs text-gray-500 mt-1"></p>
      </div>

      <div>
        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">
          Confirm Password
        </label>
        <input type="password" name="confirm_password" id="cpw" required autocomplete="new-password"
          class="input-field w-full px-4 py-3 rounded-xl text-sm text-gray-100 placeholder-gray-600"
          placeholder="Repeat password" />
        <p id="matchLabel" class="text-xs mt-1 hidden"></p>
      </div>

      <button type="submit" class="btn-primary w-full py-3 rounded-xl text-sm mt-2">
        Create Account →
      </button>
    </form>

    <p class="mt-6 text-center text-sm text-gray-500">
      Already have an account?
      <a href="/login" class="text-emerald-400 hover:underline font-semibold">Login</a>
    </p>
  </div>
</div>

<% block('scripts').append(`
<script>
  document.getElementById('togglePw').addEventListener('click', function () {
    const pw = document.getElementById('pw');
    pw.type = pw.type === 'password' ? 'text' : 'password';
    this.textContent = pw.type === 'password' ? '👁' : '🙈';
  });

  function getStrength(pw) {
    let score = 0;
    if (pw.length >= 6) score++;
    if (pw.length >= 10) score++;
    if (/[A-Z]/.test(pw)) score++;
    if (/[0-9]/.test(pw)) score++;
    if (/[^A-Za-z0-9]/.test(pw)) score++;
    return score;
  }

  const pwInput     = document.getElementById('pw');
  const cpwInput    = document.getElementById('cpw');
  const strengthBar = document.getElementById('strengthBar');
  const strengthLbl = document.getElementById('strengthLabel');
  const matchLbl    = document.getElementById('matchLabel');

  const LEVELS = [
    { label: '',          color: '',               pct: '0%'   },
    { label: 'Weak',      color: 'bg-red-500',      pct: '20%'  },
    { label: 'Fair',      color: 'bg-orange-400',   pct: '40%'  },
    { label: 'Good',      color: 'bg-yellow-400',   pct: '60%'  },
    { label: 'Strong',    color: 'bg-emerald-400',  pct: '80%'  },
    { label: 'Excellent', color: 'bg-emerald-500',  pct: '100%' },
  ];

  pwInput.addEventListener('input', function () {
    const s = getStrength(this.value);
    const l = LEVELS[s] || LEVELS[0];
    strengthBar.style.width = l.pct;
    strengthBar.className   = \`strength-bar \${l.color}\`;
    strengthLbl.textContent = l.label;
    checkMatch();
  });

  cpwInput.addEventListener('input', checkMatch);

  function checkMatch() {
    if (!cpwInput.value) { matchLbl.classList.add('hidden'); return; }
    const ok = pwInput.value === cpwInput.value;
    matchLbl.classList.remove('hidden');
    matchLbl.textContent = ok ? '✓ Passwords match' : '✗ Passwords do not match';
    matchLbl.className   = \`text-xs mt-1 \${ok ? 'text-emerald-400' : 'text-red-400'}\`;
  }

  document.getElementById('signupForm').addEventListener('submit', function (e) {
    if (pwInput.value !== cpwInput.value) {
      e.preventDefault();
      matchLbl.classList.remove('hidden');
      matchLbl.textContent = '✗ Passwords do not match';
      matchLbl.className   = 'text-xs mt-1 text-red-400';
    }
  });
</script>
`) %>
