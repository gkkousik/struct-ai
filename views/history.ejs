<% layout('layout') -%>

<% block('head').append(`
<style>
  .hist-card { transition: transform .25s, box-shadow .25s; }
  .hist-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 0 24px rgba(16,185,129,.15), 0 0 48px rgba(124,58,237,.1);
  }
  .thumb {
    background: repeating-conic-gradient(rgba(255,255,255,.02) 0% 25%, transparent 0% 50%)
                0 0 / 16px 16px, rgba(5,10,20,.8);
    height: 160px; display: flex; align-items: center; justify-content: center; overflow: hidden;
  }
  .tag-pill {
    font-size: .65rem; padding: .15rem .55rem; border-radius: 999px;
    background: rgba(16,185,129,.1); border: 1px solid rgba(16,185,129,.25);
    color: #6ee7b7; font-weight: 600; letter-spacing: .05em;
  }
  .theme-pill {
    font-size: .65rem; padding: .15rem .55rem; border-radius: 999px;
    background: rgba(124,58,237,.1); border: 1px solid rgba(124,58,237,.25);
    color: #c4b5fd; font-weight: 600;
  }
  #modal { backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); }
  #modal pre {
    font-family: 'JetBrains Mono', monospace; font-size: .75rem; line-height: 1.6;
    white-space: pre-wrap; word-break: break-all; max-height: 260px; overflow-y: auto;
  }
</style>
`) %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 py-8">

  <div class="flex items-center justify-between flex-wrap gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-extrabold gradient-text">My Diagrams</h1>
      <p class="text-gray-400 text-sm mt-0.5">
        <%= history.length %> diagram<%= history.length !== 1 ? 's' : '' %> saved
      </p>
    </div>
    <a href="/try" class="btn-primary px-5 py-2.5 rounded-xl text-sm flex items-center gap-2">
      ✦ New Diagram
    </a>
  </div>

  <% if (!history.length) { %>
  <div class="glass rounded-2xl p-16 text-center" data-aos="fade-up">
    <p class="text-5xl mb-4">📐</p>
    <h3 class="text-lg font-bold text-gray-300 mb-2">No diagrams yet</h3>
    <p class="text-gray-500 text-sm mb-6">Generate your first UML diagram and it will appear here.</p>
    <a href="/try" class="btn-primary px-8 py-3 rounded-xl text-sm inline-block">
      Generate Now
    </a>
  </div>

  <% } else { %>
  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-5">
    <% history.forEach((entry, i) => { %>
    <div class="glass hist-card rounded-2xl overflow-hidden" data-aos="fade-up" data-aos-delay="<%= (i % 3) * 60 %>">

      <div class="thumb">
        <img
          src="<%= entry.image_path %>"
          alt="<%= entry.project %>"
          class="max-h-full max-w-full object-contain"
          loading="lazy"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div style="display:none;" class="flex-col items-center gap-2 text-gray-600">
          <span class="text-3xl">🖼</span>
          <span class="text-xs">Image unavailable</span>
        </div>
      </div>

      <div class="p-5">
        <h3 class="font-bold text-gray-100 truncate mb-2" title="<%= entry.project %>">
          <%= entry.project %>
        </h3>
        <div class="flex flex-wrap gap-1.5 mb-3">
          <span class="tag-pill"><%= entry.diagram_type %></span>
          <span class="theme-pill"><%= entry.theme %></span>
        </div>
        <p class="text-xs text-gray-500 mb-4">
          <%= entry.created_at.slice(0, 10) %> at <%= entry.created_at.slice(11, 16) %> UTC
        </p>

        <div class="flex gap-2">
          <button
            class="btn-secondary flex-1 py-1.5 rounded-lg text-xs text-center view-btn"
            data-id="<%= entry.id %>"
            data-image="<%= entry.image_path %>"
            data-syntax="<%= entry.syntax %>">
            👁 View
          </button>
          <a href="<%= entry.image_path %>"
             download="<%= entry.project.replace(/ /g, '_') %>_<%= entry.diagram_type.replace(/ /g, '_') %>.png"
             class="btn-secondary flex-1 py-1.5 rounded-lg text-xs text-center">
            ⬇ PNG
          </a>
          <button onclick="deleteEntry('<%= entry.id %>', this)"
            class="bg-red-950/40 border border-red-800/40 hover:bg-red-900/50 text-red-400 px-3 py-1.5 rounded-lg text-xs transition">
            🗑
          </button>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>

<div id="modal" class="fixed inset-0 bg-black/80 z-50 hidden flex items-center justify-center p-4">
  <div class="glass rounded-2xl w-full max-w-2xl max-h-[90vh] overflow-y-auto p-6">
    <div class="flex items-center justify-between mb-5">
      <h3 class="text-lg font-bold text-emerald-400">Diagram Details</h3>
      <button onclick="closeModal()" class="text-gray-400 hover:text-white text-2xl leading-none">×</button>
    </div>

    <img id="modalImg" src="" alt="Diagram" class="rounded-xl border border-white/8 w-full mb-5" />

    <div class="flex items-center justify-between mb-2">
      <h4 class="text-sm font-semibold text-gray-300">PlantUML Syntax</h4>
      <button id="modalCopyBtn" class="btn-secondary px-3 py-1 rounded-lg text-xs">📋 Copy</button>
    </div>
    <pre id="modalSyntax" class="bg-black/50 p-4 rounded-xl text-gray-300 border border-white/6"></pre>
  </div>
</div>

<% block('scripts').append(`
<script>
  function viewEntry(id, syntax, imgUrl) {
    document.getElementById('modalImg').src = imgUrl;
    document.getElementById('modalSyntax').textContent = syntax;
    document.getElementById('modal').classList.remove('hidden');
  }

  document.querySelectorAll('.view-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      viewEntry(btn.dataset.id, btn.dataset.syntax, btn.dataset.image);
    });
  });

  function closeModal() {
    document.getElementById('modal').classList.add('hidden');
  }

  document.getElementById('modal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });

  document.getElementById('modalCopyBtn').addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(document.getElementById('modalSyntax').textContent);
      showToast('Syntax copied!', 'success');
    } catch {
      showToast('Copy failed', 'error');
    }
  });

  async function deleteEntry(id, btn) {
    if (!confirm('Delete this diagram? This cannot be undone.')) return;
    const card = btn.closest('.hist-card');
    try {
      const res = await fetch(\`/api/history/\${id}\`, { method: 'DELETE' });
      if (!res.ok) throw new Error((await res.json()).error);
      card.style.transition = 'opacity .3s, transform .3s';
      card.style.opacity    = '0';
      card.style.transform  = 'scale(.95)';
      setTimeout(() => card.remove(), 300);
      showToast('Diagram deleted.', 'success');
    } catch (err) {
      showToast(err.message, 'error');
    }
  }

  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
`) %>
