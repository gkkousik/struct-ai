# ── MongoDB ───────────────────────────────────────────────────────────────
# Local:   mongodb://127.0.0.1:27017/structura
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/structura
MONGODB_URI=mongodb://127.0.0.1:27017/structura

# ── Sessions ──────────────────────────────────────────────────────────────
# Any long random string. Sessions are stored in MongoDB (connect-mongo),
# so they survive server restarts and work across multiple instances.
SESSION_SECRET=change-this-to-a-long-random-string

# ── Groq AI (https://console.groq.com/keys) ──────────────────────────────
GROQ_API_KEY=gsk_your_key_here

# ── Server ────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
